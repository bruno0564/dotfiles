[general]
framerate = 60
bars = 0
bar_width = 2
bar_spacing = 1
sensitivity = 80

[input]
method = pipewire
source = auto

[output]
method = noncurses
channels = stereo
mono_option = average

[color]
gradient = 1
gradient_count = 4
gradient_color_1 = '{{colors.surface_bright.default.hex}}'
gradient_color_2 = '{{colors.secondary.default.hex}}'
gradient_color_3 = '{{colors.tertiary.default.hex}}'
gradient_color_4 = '{{colors.primary.default.hex}}'

[smoothing]
monstercat = 1
noise_reduction = 66
